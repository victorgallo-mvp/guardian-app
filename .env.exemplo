# ==========================================
# Banco de dados
# ==========================================
MONGO_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/guardiao-wpp

# ==========================================
# Anthropic (Claude)
# ==========================================
ANTHROPIC_API_KEY=sk-ant-...
MODELO_TRIAGEM=claude-haiku-4-5
MODELO_ANALISE=claude-sonnet-4-5

# ==========================================
# Evolution API (instância principal)
# Multi-tenant completo configura instância por Cliente no Mongo,
# mas estas variáveis servem como fallback/instância padrão
# ==========================================
EVOLUTION_API_URL=https://sua-instancia.com
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=

# ==========================================
# Cliente atual (mono-tenant operacional)
# ==========================================
CLIENT_ID=agencia-cobaia

# ==========================================
# Limites e segurança
# ==========================================
LIMITE_CUSTO_DIARIO_USD=5.00
ADMIN_TOKEN=troque-este-token-por-um-seguro

# ==========================================
# Servidor
# ==========================================
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ==========================================
# Webhooks (URL pública que a Evolution API vai chamar)
# ==========================================
WEBHOOK_URL_BASE=https://seu-app.up.railway.app
